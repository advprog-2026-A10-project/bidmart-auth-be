APP_HOST=0.0.0.0
APP_PORT=8080

# Neon Postgres URL
DATABASE_URL=postgres://user:password@ep-example-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DB_MAX_CONNECTIONS=10

# HS256 secret. Use at least 32 chars.
JWT_SECRET=replace-with-a-long-random-secret-value
JWT_EXPIRY_MINUTES=60

# Use "*" for local dev or set a frontend origin.
CORS_ORIGIN=*
